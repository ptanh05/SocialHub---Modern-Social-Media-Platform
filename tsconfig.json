{
    "compilerOptions": {
        "target": "ES6",
        "lib": ["dom", "dom.iterable", "esnext"],

        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,

        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",

        "incremental": true,

        "plugins": [
            {
                "name": "next"
            }
        ],

        // 🔥 FIX ALIAS
        "baseUrl": ".",
        "paths": {
            "@/*": ["./*"]
        },

        // 🔥 TẮT WARNING TS 6
        "ignoreDeprecations": "6.0"
    },

    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        ".next/dev/types/**/*.ts"
    ],

    "exclude": ["node_modules"]
}
